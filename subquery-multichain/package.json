{
  "name": "nodle-bridge-multichain",
  "version": "0.0.1",
  "description": "SubQuery Multi-Chain Project for NODL Bridge (Ethereum L1 and zkSync L2)",
  "main": "dist/index.js",
  "scripts": {
    "codegen": "npm run export:env && subql codegen subquery-multichain.yaml",
    "build": "npm run export:env && subql build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:failed": "jest --onlyFailures",
    "publish": "subql publish",
    "export:env": "export $(grep -v '^#' .env | xargs)",
    "start:docker": "npm run export:env && docker-compose pull && docker-compose up --remove-orphans",
    "dev": "npm run export:env && npm run codegen && npm run prepack && docker-compose pull && docker-compose up --remove-orphans",
    "prepack": "rm -rf dist && npm run build"
  },
  "files": [
    "dist",
    "schema.graphql",
    "subquery-multichain.yaml"
  ],
  "dependencies": {
    "@subql/common": "^5.8.2",
    "@subql/common-ethereum": "^4.10.1",
    "@subql/types-ethereum": "^4.2.3",
    "@subql/validator": "^2.2.0",
    "@types/node-fetch": "^2.6.13",
    "assert": "^2.1.0",
    "dotenv": "^16.4.5",
    "node-fetch": "2.6.7"
  },
  "devDependencies": {
    "@subql/cli": "^6.6.2",
    "@subql/node-ethereum": "^6.3.1",
    "@subql/testing": "^2.3.1",
    "@subql/types": "^3.15.0",
    "@typechain/ethers-v5": "^11.1.2",
    "@types/jest": "^29.5.12",
    "@types/node-fetch": "^2.6.13",
    "ethers": "^5.1.3",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.6.3"
  }
}
